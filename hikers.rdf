        <rdfs:label xml:lang="en">Terrain</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/ThermalSuit -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/ThermalSuit">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Base"/>
        <rdfs:comment xml:lang="en">Full-body insulated base layer clothing for extreme cold conditions.</rdfs:comment>
        <rdfs:label xml:lang="en">Thermal Suit</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Tools -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Tools">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Equipment"/>
