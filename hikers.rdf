            <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/Rope"/>
            <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/Snowshoes"/>
            <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/Tent"/>
        </owl:disjointUnionOf>
        <rdfs:comment xml:lang="en">Specialized equipment and tools for hiking, including poles, ropes, crampons, and camping gear.</rdfs:comment>
        <rdfs:label xml:lang="en">Tools</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Trail -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Trail">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:comment xml:lang="en">A hiking or trekking route that can be characterized by terrain, weather conditions, and activity type.</rdfs:comment>
        <rdfs:label xml:lang="en">Trail</rdfs:label>
    </owl:Class>
    


