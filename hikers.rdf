    </rdf:Description>
    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/d2">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/d1">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/p">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/date">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/x">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>The rule implies that an outer shell is raining if rain is forecast for a hike</rdfs:comment>
        <rdfs:label>OuterShell_Req</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="http://www.unito.it/ontologies/trekconsult/hasPrecipitation"/>
                        <swrl:argument1 rdf:resource="http://www.unito.it/ontologies/trekconsult/t"/>
                        <swrl:argument2 rdf:resource="http://www.unito.it/ontologies/trekconsult/p"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.unito.it/ontologies/trekconsult/basicEquipement"/>
                                <swrl:argument1 rdf:resource="http://www.unito.it/ontologies/trekconsult/o"/>
                                <swrl:argument2 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrl:argument2>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                        <swrl:classPredicate rdf:resource="http://www.unito.it/ontologies/trekconsult/Rain"/>
                                        <swrl:argument1 rdf:resource="http://www.unito.it/ontologies/trekconsult/p"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                        <rdf:first>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#BuiltinAtom"/>
                                                <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#equal"/>
                                                <swrl:arguments rdf:parseType="Collection">
                                                    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/d1"/>
                                                    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/d2"/>
                                                </swrl:arguments>
                                            </rdf:Description>
                                        </rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                <rdf:first>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                                        <swrl:classPredicate rdf:resource="http://www.unito.it/ontologies/trekconsult/Hike"/>
                                                        <swrl:argument1 rdf:resource="http://www.unito.it/ontologies/trekconsult/h"/>
                                                    </rdf:Description>
                                                </rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                        <rdf:first>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                                                <swrl:classPredicate rdf:resource="http://www.unito.it/ontologies/trekconsult/Trail"/>
                                                                <swrl:argument1 rdf:resource="http://www.unito.it/ontologies/trekconsult/t"/>
                                                            </rdf:Description>
                                                        </rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                                <rdf:first>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                                                        <swrl:propertyPredicate rdf:resource="http://www.unito.it/ontologies/trekconsult/hikeDate"/>
                                                                        <swrl:argument1 rdf:resource="http://www.unito.it/ontologies/trekconsult/h"/>
                                                                        <swrl:argument2 rdf:resource="http://www.unito.it/ontologies/trekconsult/d2"/>
                                                                    </rdf:Description>
                                                                </rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                                        <rdf:first>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                                                                <swrl:propertyPredicate rdf:resource="http://www.unito.it/ontologies/trekconsult/precipitationInDate"/>
                                                                                <swrl:argument1 rdf:resource="http://www.unito.it/ontologies/trekconsult/p"/>
                                                                                <swrl:argument2 rdf:resource="http://www.unito.it/ontologies/trekconsult/d1"/>
                                                                            </rdf:Description>
                                                                        </rdf:first>
                                                                        <rdf:rest>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                                                <rdf:first>
                                                                                    <rdf:Description>
                                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                                                        <swrl:propertyPredicate rdf:resource="http://www.unito.it/ontologies/trekconsult/chalanges"/>
                                                                                        <swrl:argument1 rdf:resource="http://www.unito.it/ontologies/trekconsult/h"/>
                                                                                        <swrl:argument2 rdf:resource="http://www.unito.it/ontologies/trekconsult/t"/>
                                                                                    </rdf:Description>
                                                                                </rdf:first>
