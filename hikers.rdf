<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult/"
     xml:base="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:geos="http://www.opengis.net/ont/geosparql#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:sweet="http://sweetontology.net/matrPrecipitation/"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:sweetpa="http://sweetontology.net/phenAtmo/"
     xmlns:trekconsult="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#chalanges -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#chalanges">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hike"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail"/>
        <rdfs:comment>A organized hike involves chalanging a certain mountain trail</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasEquipement -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasEquipement">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hike"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Equipment"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasEquipementSet"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasMember"/>
        </owl:propertyChainAxiom>
        <rdfs:comment>A certain equipment can be used on a organized Hike.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasEquipementSet -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasEquipementSet">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hike"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#EquipmentSet"/>
        <rdfs:comment>Own a set of equipments</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasMember -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasMember">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#isMemberOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#EquipmentSet"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Equipment"/>
        <rdfs:comment>A colection has a certain member</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasPrecipitation -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasPrecipitation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Precipitation"/>
        <rdfs:comment>A trail retrieves the presence of a certain athmoferical precipitation</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasSeason -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasSeason">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hike"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Season"/>
        <rdfs:comment>The season when a certain event takes place</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasTerrain -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasTerrain">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Terrain"/>
        <rdfs:comment>A certain trail return a certain terrain status</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasWeather -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasWeather">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Weather"/>
        <rdfs:comment>A trail retrieves a certain weather status for certain date</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#isMemberOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#isMemberOf">
        <rdfs:comment>Is a member of a certain collection</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#requiresEquipement -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#requiresEquipement">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hike"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Equipment"/>
        <rdfs:comment>A certain trail can require a certain equipment</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2002/07/owl#topObjectProperty -->

    <rdf:Description rdf:about="http://www.w3.org/2002/07/owl#topObjectProperty">
        <owl:inverseOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </rdf:Description>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#basicEquipement -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#basicEquipement">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Equipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>The equipment is the entry level option</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#circularTrail -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#circularTrail">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>The trail is closed</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#distanceTrail -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#distanceTrail">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>The lenght in KM of a trail</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasCapacity -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasCapacity">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Equipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment>The capacity of a backpack</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasElevationGain -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasElevationGain">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment>A trail has an elevation gain</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasTemperatureValue -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasTemperatureValue">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Weather"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>The weather temperature in Celsius</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hikeDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hikeDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hike"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The date when the hike is organized</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#isWaterProof -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#isWaterProof">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Equipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Describes if the equipment is waterproof</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#precipitationInDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#precipitationInDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Precipitation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Describe the date when a particular atmospherical precipitation has taken place</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#reacheableByTrain -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#reacheableByTrain">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Is true when a certain trail is reacheable by trail</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#requiresCar -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#requiresCar">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>A trail is reacheable only by car</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#requiresWater -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#requiresWater">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>If the trail doesn&apos;t have some point where to collect water, the a water tank from home is required</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#terrainInDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#terrainInDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Terrain"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Describes the date where a certain terain status of trail is checked.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#trailLevel -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#trailLevel">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Decribes the dificulty of the trail</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#weatherInDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#weatherInDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Weather"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Describes the date were the weather conditions were forecast.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://dbpedia.org/ontology/Device -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/Device"/>
    


    <!-- http://sweetontology.net/phenAtmoPrecipitation/AtmosphericPrecipitation -->

    <owl:Class rdf:about="http://sweetontology.net/phenAtmoPrecipitation/AtmosphericPrecipitation">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Precipitation"/>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->

    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Feature"/>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Axe -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Axe">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tools"/>
        <rdfs:comment xml:lang="en">A cutting tool used for chopping wood or clearing vegetation on trails.</rdfs:comment>
        <rdfs:label xml:lang="en">Axe</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Backpack -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Backpack">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Equipment"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#LargeBackpack"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#MidBackpack"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#SmallBackpack"/>
        </owl:disjointUnionOf>
        <rdfs:comment xml:lang="en">A bag carried on one&apos;s back for holding equipment and supplies during hiking.</rdfs:comment>
        <rdfs:label xml:lang="en">Backpack</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Base -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Base">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Layer"/>
        <rdfs:comment xml:lang="en">The innermost layer of clothing worn next to the skin, designed for moisture wicking and temperature regulation.</rdfs:comment>
        <rdfs:label xml:lang="en">Base Layer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Closed -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Closed">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Terrain"/>
        <rdfs:comment xml:lang="en">Terrain characterized by dense vegetation, forests, or narrow paths with limited visibility.</rdfs:comment>
        <rdfs:label xml:lang="en">Closed Terrain</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Cold -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Cold">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Weather"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasTemperatureValue"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#float">10.0</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Weather"/>
        <rdfs:comment xml:lang="en">Weather conditions with temperatures below 10 degrees Celsius.</rdfs:comment>
        <rdfs:label xml:lang="en">Cold Weather</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Equipment -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Equipment">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Device"/>
        <rdfs:comment xml:lang="en">General category for all hiking and trekking equipment including clothing, tools, and accessories.</rdfs:comment>
        <rdfs:label xml:lang="en">Equipement</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#EquipmentSet -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#EquipmentSet">
        <rdfs:comment xml:lang="en">An equipment set</rdfs:comment>
        <rdfs:label xml:lang="en">Equipment Set</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Ferrata -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Ferrata">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail"/>
        <rdfs:comment xml:lang="en">A protected climbing route with fixed cables, ladders, and bridges allowing access to difficult terrain.</rdfs:comment>
        <rdfs:label xml:lang="en">Via Ferrata</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Fleece -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Fleece">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Mid"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#WoolHoodie"/>
        <rdfs:comment xml:lang="en">A synthetic mid-layer garment made from fleece material for warmth and insulation.</rdfs:comment>
        <rdfs:label xml:lang="en">Fleece</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Glasses -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Glasses">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tools"/>
        <rdfs:comment xml:lang="en">Protective eyewear for sun protection and visibility enhancement during hiking.</rdfs:comment>
        <rdfs:label xml:lang="en">Glasses</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Harness -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Harness">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tools"/>
        <rdfs:comment xml:lang="en">A safety harness used for climbing and via ferrata routes.</rdfs:comment>
        <rdfs:label xml:lang="en">Harness</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hat -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hat">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Equipment"/>
        <rdfs:comment xml:lang="en">Headwear for protection from sun, cold, or other weather conditions.</rdfs:comment>
        <rdfs:label xml:lang="en">Hat</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Helmet -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Helmet">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tools"/>
        <rdfs:comment xml:lang="en">Protective headgear for safety during climbing, via ferrata, or technical trails.</rdfs:comment>
        <rdfs:label xml:lang="en">Helmet</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#HighShoes -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#HighShoes">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Shoes"/>
        <rdfs:comment xml:lang="en">High-cut hiking boots providing maximum ankle support and stability for difficult terrain.</rdfs:comment>
        <rdfs:label xml:lang="en">High Shoes</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hike -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hike">
        <rdfs:comment>An organized hike that chalanges a particular trail</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hot -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hot">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Weather"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasTemperatureValue"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#float">25.0</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Weather"/>
        <rdfs:comment xml:lang="en">Weather conditions with temperatures at or above 25 degrees Celsius.</rdfs:comment>
        <rdfs:label xml:lang="en">Hot Weather</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Iced -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Iced">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Terrain"/>
        <rdfs:comment xml:lang="en">Terrain covered with ice, requiring specialized equipment like crampons.</rdfs:comment>
        <rdfs:label xml:lang="en">Iced Terrain</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Insulation -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Insulation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Layer"/>
        <rdfs:comment xml:lang="en">Middle clothing layer designed to provide warmth by trapping body heat.</rdfs:comment>
        <rdfs:label xml:lang="en">Insulation Layer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#LargeBackpack -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#LargeBackpack">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Backpack"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasCapacity"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#positiveInteger">60</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Backpack"/>
        <rdfs:comment xml:lang="en">A large-capacity backpack (typically 50+ liters) for multi-day treks and extended expeditions.</rdfs:comment>
        <rdfs:label xml:lang="en">Large Backpack</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Layer -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Layer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Equipment"/>
        <rdfs:comment xml:lang="en">Clothing layers used in the layering system for outdoor activities (base, mid, insulation, outer shell, pants).</rdfs:comment>
        <rdfs:label xml:lang="en">Layer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#LongPants -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#LongPants">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Pants"/>
        <rdfs:comment xml:lang="en">Full-length pants providing protection from cold, insects, and vegetation.</rdfs:comment>
        <rdfs:label xml:lang="en">Long Pants</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#LowShoes -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#LowShoes">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Shoes"/>
        <rdfs:comment xml:lang="en">Low-cut hiking shoes or trail runners, suitable for easy trails and day hikes.</rdfs:comment>
        <rdfs:label xml:lang="en">Low Shoes</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Mid -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Mid">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Layer"/>
        <rdfs:comment xml:lang="en">Middle clothing layer providing additional insulation and moisture management.</rdfs:comment>
        <rdfs:label xml:lang="en">Mid Layer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#MidBackpack -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#MidBackpack">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Backpack"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasCapacity"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#positiveInteger">20</xsd:minExclusive>
                                    </rdf:Description>
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#positiveInteger">60</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Backpack"/>
        <rdfs:comment xml:lang="en">A medium-capacity backpack (typically 30-50 liters) for day hikes and short overnight trips.</rdfs:comment>
        <rdfs:label xml:lang="en">Medium Backpack</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#MidShoes -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#MidShoes">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Shoes"/>
        <rdfs:comment xml:lang="en">Mid-cut hiking boots providing ankle support and stability on moderate terrain.</rdfs:comment>
        <rdfs:label xml:lang="en">Mid Shoes</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Mild -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Mild">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Weather"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasTemperatureValue"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#float">10.0</xsd:minInclusive>
                                    </rdf:Description>
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#float">25.0</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Weather"/>
        <rdfs:comment xml:lang="en">Weather conditions with moderate temperatures between 10 and 25 degrees Celsius.</rdfs:comment>
        <rdfs:label xml:lang="en">Mild Weather</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Mountaneering -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Mountaneering">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail"/>
        <rdfs:comment xml:lang="en">A technical mountain trail requiring specialized climbing skills and equipment.</rdfs:comment>
        <rdfs:label xml:lang="en">Mountaineering</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#OuterShell -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#OuterShell">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Layer"/>
        <rdfs:comment xml:lang="en">Outermost clothing layer providing protection from wind, rain, and snow.</rdfs:comment>
        <rdfs:label xml:lang="en">Outer Shell</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Pants -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Pants">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Layer"/>
        <rdfs:comment xml:lang="en">Lower body clothing for hiking, including both long and short variants.</rdfs:comment>
        <rdfs:label xml:lang="en">Pants</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Poles -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Poles">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tools"/>
        <rdfs:comment xml:lang="en">Walking poles used for stability, balance, and reducing strain on knees during hiking.</rdfs:comment>
        <rdfs:label xml:lang="en">Trekking Poles</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Precipitation -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Precipitation">
        <rdfs:comment xml:lang="en">Any form of water falling from the atmosphere, including rain, snow, and hail.</rdfs:comment>
        <rdfs:label xml:lang="en">Precipitation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Rain -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Rain">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Precipitation"/>
        <rdfs:comment xml:lang="en">Precipitation in the form of liquid water droplets.</rdfs:comment>
        <rdfs:label xml:lang="en">Rain</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Rampons -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Rampons">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tools"/>
        <rdfs:comment xml:lang="en">Traction devices with metal spikes attached to footwear for walking on ice and snow.</rdfs:comment>
        <rdfs:label xml:lang="en">Crampons</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Rope -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Rope">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tools"/>
        <rdfs:comment xml:lang="en">Climbing or safety rope used for technical sections, river crossings, or emergency situations.</rdfs:comment>
        <rdfs:label xml:lang="en">Rope</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Season -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Season">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Autumn"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Spring"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Summer"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Winter"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">The four seasons of the year: Spring, Summer, Autumn, and Winter.</rdfs:comment>
        <rdfs:label xml:lang="en">Season</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Shirt -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Shirt">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Base"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#ThermalSuit"/>
        <rdfs:comment xml:lang="en">Upper body base layer garment for moisture management and comfort.</rdfs:comment>
        <rdfs:label xml:lang="en">Shirt</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Shoes -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Shoes">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Equipment"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#HighShoes"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#LowShoes"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#MidShoes"/>
        </owl:disjointUnionOf>
        <rdfs:comment xml:lang="en">Footwear for hiking, including low, mid, and high-cut options for different terrain types.</rdfs:comment>
        <rdfs:label xml:lang="en">Shoes</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#ShortPants -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#ShortPants">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Pants"/>
        <rdfs:comment xml:lang="en">Shorts or short pants suitable for warm weather hiking.</rdfs:comment>
        <rdfs:label xml:lang="en">Short Pants</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#SmallBackpack -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#SmallBackpack">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Backpack"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasCapacity"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#positiveInteger">20</xsd:maxInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Backpack"/>
        <rdfs:comment xml:lang="en">A small-capacity backpack (typically under 30 liters) for short day hikes.</rdfs:comment>
        <rdfs:label xml:lang="en">Small Backpack</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Snow -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Snow">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Precipitation"/>
        <rdfs:comment xml:lang="en">Precipitation in the form of ice crystals.</rdfs:comment>
        <rdfs:label xml:lang="en">Snow</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Snowshoes -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Snowshoes">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tools"/>
        <rdfs:comment xml:lang="en">Footwear designed to distribute weight over a larger area for walking on snow.</rdfs:comment>
        <rdfs:label xml:lang="en">Snowshoes</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Snowy -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Snowy">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Terrain"/>
        <rdfs:comment xml:lang="en">Terrain covered with snow, requiring specialized equipment like snowshoes or crampons.</rdfs:comment>
        <rdfs:label xml:lang="en">Snowy Terrain</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#SunHat -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#SunHat">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hat"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#WoolHat"/>
        <rdfs:comment xml:lang="en">A wide-brimmed hat for protection from sun exposure.</rdfs:comment>
        <rdfs:label xml:lang="en">Sun Hat</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tent -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tent">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tools"/>
        <rdfs:comment xml:lang="en">Portable shelter for camping during multi-day hikes.</rdfs:comment>
        <rdfs:label xml:lang="en">Tent</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Terrain -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Terrain">
        <rdfs:comment xml:lang="en">The physical characteristics and surface type of a trail (open, closed, snowy, iced, etc.).</rdfs:comment>
        <rdfs:label xml:lang="en">Terrain</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#ThermalSuit -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#ThermalSuit">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Base"/>
        <rdfs:comment xml:lang="en">Full-body insulated base layer clothing for extreme cold conditions.</rdfs:comment>
        <rdfs:label xml:lang="en">Thermal Suit</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tools -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tools">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Equipment"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Axe"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Glasses"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Harness"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Helmet"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Poles"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Rampons"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Rope"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Snowshoes"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tent"/>
        </owl:disjointUnionOf>
        <rdfs:comment xml:lang="en">Specialized equipment and tools for hiking, including poles, ropes, crampons, and camping gear.</rdfs:comment>
        <rdfs:label xml:lang="en">Tools</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:comment xml:lang="en">A hiking or trekking route that can be characterized by terrain, weather conditions, and activity type.</rdfs:comment>
        <rdfs:label xml:lang="en">Trail</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Treking -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Treking">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail"/>
        <rdfs:comment xml:lang="en">A simple mountain trail</rdfs:comment>
        <rdfs:label xml:lang="en">Trekking</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Weather -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Weather">
        <rdfs:comment xml:lang="en">Atmospheric conditions affecting a trail, including temperature, precipitation, and humidity.</rdfs:comment>
        <rdfs:label xml:lang="en">Weather</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#WoolHat -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#WoolHat">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hat"/>
        <rdfs:comment xml:lang="en">A warm hat made of wool for cold weather protection.</rdfs:comment>
        <rdfs:label xml:lang="en">Wool Hat</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#WoolHoodie -->

    <owl:Class rdf:about="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#WoolHoodie">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Mid"/>
        <rdfs:comment xml:lang="en">A hooded mid-layer garment made of wool for warmth and comfort.</rdfs:comment>
        <rdfs:label xml:lang="en">Wool Hoodie</rdfs:label>
    </owl:Class>
    


