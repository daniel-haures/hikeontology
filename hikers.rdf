<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.unito.it/ontologies/trekconsult/"
     xml:base="http://www.unito.it/ontologies/trekconsult/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:geos="http://www.opengis.net/ont/geosparql#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:sweet="http://sweetontology.net/matrPrecipitation/"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:sweetpa="http://sweetontology.net/phenAtmo/"
     xmlns:trekconsult="http://www.unito.it/ontologies/trekconsult#">
    <owl:Ontology rdf:about="http://www.unito.it/ontologies/trekconsult">
        <dc:creator>Daniel Haures</dc:creator>
        <dc:date>2026-06-01</dc:date>
        <dc:description>Ontology for mountain trail discovery and equipement recomendation.</dc:description>
        <dc:title>TrekConsult</dc:title>
        <vann:preferredNamespacePrefix>trekconsult</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://ww.unito.it/ontologies/trekconsult</vann:preferredNamespaceUri>
        <rdfs:label>TrekConsult</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/date -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/date"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->

    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->

    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.unito.it/ontologies/trekconsult/chalanges -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/ontologies/trekconsult/chalanges">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Hike"/>
        <rdfs:range rdf:resource="http://www.unito.it/ontologies/trekconsult/Trail"/>
        <rdfs:comment>A organized hike involves chalanging a certain mountain trail</rdfs:comment>
        <rdfs:label>challenges</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/hasEquipement -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/ontologies/trekconsult/hasEquipement">
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Hike"/>
        <rdfs:range rdf:resource="http://www.unito.it/ontologies/trekconsult/Equipment"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/hasEquipementSet"/>
            <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/hasMember"/>
        </owl:propertyChainAxiom>
        <rdfs:comment>A certain equipment can be used on a organized Hike.</rdfs:comment>
        <rdfs:label>has equipment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/hasEquipementSet -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/ontologies/trekconsult/hasEquipementSet">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Hike"/>
        <rdfs:range rdf:resource="http://www.unito.it/ontologies/trekconsult/EquipmentSet"/>
        <rdfs:comment>Own a set of equipments</rdfs:comment>
        <rdfs:label>has equipment set</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/hasMember -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/ontologies/trekconsult/hasMember">
        <owl:inverseOf rdf:resource="http://www.unito.it/ontologies/trekconsult/isMemberOf"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/EquipmentSet"/>
        <rdfs:range rdf:resource="http://www.unito.it/ontologies/trekconsult/Equipment"/>
        <rdfs:comment>A colection has a certain member</rdfs:comment>
        <rdfs:label>has member</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/hasPrecipitation -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/ontologies/trekconsult/hasPrecipitation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Trail"/>
        <rdfs:range rdf:resource="http://www.unito.it/ontologies/trekconsult/Precipitation"/>
        <rdfs:comment>A trail retrieves the presence of a certain athmoferical precipitation</rdfs:comment>
        <rdfs:label>has precipitation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/hasSeason -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/ontologies/trekconsult/hasSeason">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Hike"/>
        <rdfs:range rdf:resource="http://www.unito.it/ontologies/trekconsult/Season"/>
        <rdfs:comment>The season when a certain event takes place</rdfs:comment>
        <rdfs:label>has season</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/hasTerrain -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/ontologies/trekconsult/hasTerrain">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Trail"/>
        <rdfs:range rdf:resource="http://www.unito.it/ontologies/trekconsult/Terrain"/>
        <rdfs:comment>A certain trail return a certain terrain status</rdfs:comment>
        <rdfs:label>has terrain</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/hasWeather -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/ontologies/trekconsult/hasWeather">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Trail"/>
        <rdfs:range rdf:resource="http://www.unito.it/ontologies/trekconsult/Weather"/>
        <rdfs:comment>A trail retrieves a certain weather status for certain date</rdfs:comment>
        <rdfs:label>has weather</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/isMemberOf -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/ontologies/trekconsult/isMemberOf">
        <rdfs:comment>Is a member of a certain collection</rdfs:comment>
        <rdfs:label>is member of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/requiresEquipement -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/ontologies/trekconsult/requiresEquipement">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Hike"/>
        <rdfs:range rdf:resource="http://www.unito.it/ontologies/trekconsult/Equipment"/>
        <rdfs:comment>A certain trail can require a certain equipment</rdfs:comment>
        <rdfs:label>requires equipment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2002/07/owl#topObjectProperty -->

    <rdf:Description rdf:about="http://www.w3.org/2002/07/owl#topObjectProperty">
        <owl:inverseOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </rdf:Description>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.unito.it/ontologies/trekconsult/basicEquipement -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/basicEquipement">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Equipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>The equipment is the entry level option</rdfs:comment>
        <rdfs:label>basic equipment</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/circularTrail -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/circularTrail">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Trail"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>The trail is closed</rdfs:comment>
        <rdfs:label>circular trail</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/distanceTrail -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/distanceTrail">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Trail"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>The lenght in KM of a trail</rdfs:comment>
        <rdfs:label>distance trail</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/hasCapacity -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/hasCapacity">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Equipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment>The capacity of a backpack</rdfs:comment>
        <rdfs:label>has capacity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/hasElevationGain -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/hasElevationGain">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Trail"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment>A trail has an elevation gain</rdfs:comment>
        <rdfs:label>has elevation gain</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/hasTemperatureValue -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/hasTemperatureValue">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Weather"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>The weather temperature in Celsius</rdfs:comment>
        <rdfs:label>has temperature value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/hikeDate -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/hikeDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Hike"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The date when the hike is organized</rdfs:comment>
        <rdfs:label>hike date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/isWaterProof -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/isWaterProof">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Equipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Describes if the equipment is waterproof</rdfs:comment>
        <rdfs:label>is water proof</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/precipitationInDate -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/precipitationInDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Precipitation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Describe the date when a particular atmospherical precipitation has taken place</rdfs:comment>
        <rdfs:label>precipitation in date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/reacheableByTrain -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/reacheableByTrain">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Trail"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Is true when a certain trail is reacheable by trail</rdfs:comment>
        <rdfs:label>reacheable by train</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/requiresCar -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/requiresCar">
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Trail"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>A trail is reacheable only by car</rdfs:comment>
        <rdfs:label>requires car</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/requiresWater -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/requiresWater">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Trail"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>If the trail doesn&apos;t have some point where to collect water, the a water tank from home is required</rdfs:comment>
        <rdfs:label>requires water</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/terrainInDate -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/terrainInDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Terrain"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Describes the date where a certain terain status of trail is checked.</rdfs:comment>
        <rdfs:label>terrain in date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/trailLevel -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/trailLevel">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Trail"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Decribes the dificulty of the trail</rdfs:comment>
        <rdfs:label>trail level</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/ontologies/trekconsult/weatherInDate -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/ontologies/trekconsult/weatherInDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/ontologies/trekconsult/Weather"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Describes the date were the weather conditions were forecast.</rdfs:comment>
        <rdfs:label>weather in date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://dbpedia.org/ontology/Device -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/Device"/>
    


    <!-- http://sweetontology.net/phenAtmoPrecipitation/AtmosphericPrecipitation -->

    <owl:Class rdf:about="http://sweetontology.net/phenAtmoPrecipitation/AtmosphericPrecipitation">
        <owl:equivalentClass rdf:resource="http://www.unito.it/ontologies/trekconsult/Precipitation"/>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->

    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Feature"/>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Axe -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Axe">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Tools"/>
        <rdfs:comment xml:lang="en">A cutting tool used for chopping wood or clearing vegetation on trails.</rdfs:comment>
        <rdfs:label xml:lang="en">Axe</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Backpack -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Backpack">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Equipment"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/LargeBackpack"/>
            <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/MidBackpack"/>
            <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/SmallBackpack"/>
        </owl:disjointUnionOf>
        <rdfs:comment xml:lang="en">A bag carried on one&apos;s back for holding equipment and supplies during hiking.</rdfs:comment>
        <rdfs:label xml:lang="en">Backpack</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Base -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Base">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Layer"/>
        <rdfs:comment xml:lang="en">The innermost layer of clothing worn next to the skin, designed for moisture wicking and temperature regulation.</rdfs:comment>
        <rdfs:label xml:lang="en">Base Layer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Closed -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Closed">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Terrain"/>
        <rdfs:comment xml:lang="en">Terrain characterized by dense vegetation, forests, or narrow paths with limited visibility.</rdfs:comment>
        <rdfs:label xml:lang="en">Closed Terrain</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Cold -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Cold">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/Weather"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.unito.it/ontologies/trekconsult/hasTemperatureValue"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#float">10.0</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Weather"/>
        <rdfs:comment xml:lang="en">Weather conditions with temperatures below 10 degrees Celsius.</rdfs:comment>
        <rdfs:label xml:lang="en">Cold Weather</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Equipment -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Equipment">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Device"/>
        <rdfs:comment xml:lang="en">General category for all hiking and trekking equipment including clothing, tools, and accessories.</rdfs:comment>
        <rdfs:label xml:lang="en">Equipement</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/EquipmentSet -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/EquipmentSet">
        <rdfs:comment xml:lang="en">An equipment set</rdfs:comment>
        <rdfs:label xml:lang="en">Equipment Set</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Ferrata -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Ferrata">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Trail"/>
        <rdfs:comment xml:lang="en">A protected climbing route with fixed cables, ladders, and bridges allowing access to difficult terrain.</rdfs:comment>
        <rdfs:label xml:lang="en">Via Ferrata</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Fleece -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Fleece">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Mid"/>
        <owl:disjointWith rdf:resource="http://www.unito.it/ontologies/trekconsult/WoolHoodie"/>
        <rdfs:comment xml:lang="en">A synthetic mid-layer garment made from fleece material for warmth and insulation.</rdfs:comment>
        <rdfs:label xml:lang="en">Fleece</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Glasses -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Glasses">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Tools"/>
        <rdfs:comment xml:lang="en">Protective eyewear for sun protection and visibility enhancement during hiking.</rdfs:comment>
        <rdfs:label xml:lang="en">Glasses</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Harness -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Harness">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Tools"/>
        <rdfs:comment xml:lang="en">A safety harness used for climbing and via ferrata routes.</rdfs:comment>
        <rdfs:label xml:lang="en">Harness</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Hat -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Hat">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Equipment"/>
        <rdfs:comment xml:lang="en">Headwear for protection from sun, cold, or other weather conditions.</rdfs:comment>
        <rdfs:label xml:lang="en">Hat</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Helmet -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Helmet">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Tools"/>
        <rdfs:comment xml:lang="en">Protective headgear for safety during climbing, via ferrata, or technical trails.</rdfs:comment>
        <rdfs:label xml:lang="en">Helmet</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/HighShoes -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/HighShoes">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Shoes"/>
        <rdfs:comment xml:lang="en">High-cut hiking boots providing maximum ankle support and stability for difficult terrain.</rdfs:comment>
        <rdfs:label xml:lang="en">High Shoes</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Hike -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Hike">
        <rdfs:comment>An organized hike that chalanges a particular trail</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Hot -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Hot">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/Weather"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.unito.it/ontologies/trekconsult/hasTemperatureValue"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#float">25.0</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Weather"/>
        <rdfs:comment xml:lang="en">Weather conditions with temperatures at or above 25 degrees Celsius.</rdfs:comment>
        <rdfs:label xml:lang="en">Hot Weather</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Iced -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Iced">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Terrain"/>
        <rdfs:comment xml:lang="en">Terrain covered with ice, requiring specialized equipment like crampons.</rdfs:comment>
        <rdfs:label xml:lang="en">Iced Terrain</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Insulation -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Insulation">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Layer"/>
        <rdfs:comment xml:lang="en">Middle clothing layer designed to provide warmth by trapping body heat.</rdfs:comment>
        <rdfs:label xml:lang="en">Insulation Layer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/LargeBackpack -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/LargeBackpack">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/Backpack"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.unito.it/ontologies/trekconsult/hasCapacity"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#positiveInteger">60</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Backpack"/>
        <rdfs:comment xml:lang="en">A large-capacity backpack (typically 50+ liters) for multi-day treks and extended expeditions.</rdfs:comment>
        <rdfs:label xml:lang="en">Large Backpack</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Layer -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Layer">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Equipment"/>
        <rdfs:comment xml:lang="en">Clothing layers used in the layering system for outdoor activities (base, mid, insulation, outer shell, pants).</rdfs:comment>
        <rdfs:label xml:lang="en">Layer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/LongPants -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/LongPants">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Pants"/>
        <rdfs:comment xml:lang="en">Full-length pants providing protection from cold, insects, and vegetation.</rdfs:comment>
        <rdfs:label xml:lang="en">Long Pants</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/LowShoes -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/LowShoes">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Shoes"/>
        <rdfs:comment xml:lang="en">Low-cut hiking shoes or trail runners, suitable for easy trails and day hikes.</rdfs:comment>
        <rdfs:label xml:lang="en">Low Shoes</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Mid -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Mid">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Layer"/>
        <rdfs:comment xml:lang="en">Middle clothing layer providing additional insulation and moisture management.</rdfs:comment>
        <rdfs:label xml:lang="en">Mid Layer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/MidBackpack -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/MidBackpack">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/Backpack"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.unito.it/ontologies/trekconsult/hasCapacity"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#positiveInteger">20</xsd:minExclusive>
                                    </rdf:Description>
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#positiveInteger">60</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Backpack"/>
        <rdfs:comment xml:lang="en">A medium-capacity backpack (typically 30-50 liters) for day hikes and short overnight trips.</rdfs:comment>
        <rdfs:label xml:lang="en">Medium Backpack</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/MidShoes -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/MidShoes">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Shoes"/>
        <rdfs:comment xml:lang="en">Mid-cut hiking boots providing ankle support and stability on moderate terrain.</rdfs:comment>
        <rdfs:label xml:lang="en">Mid Shoes</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Mild -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Mild">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/Weather"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.unito.it/ontologies/trekconsult/hasTemperatureValue"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#float">10.0</xsd:minInclusive>
                                    </rdf:Description>
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#float">25.0</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Weather"/>
        <rdfs:comment xml:lang="en">Weather conditions with moderate temperatures between 10 and 25 degrees Celsius.</rdfs:comment>
        <rdfs:label xml:lang="en">Mild Weather</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Mountaneering -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Mountaneering">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Trail"/>
        <rdfs:comment xml:lang="en">A technical mountain trail requiring specialized climbing skills and equipment.</rdfs:comment>
        <rdfs:label xml:lang="en">Mountaineering</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/OuterShell -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/OuterShell">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Layer"/>
        <rdfs:comment xml:lang="en">Outermost clothing layer providing protection from wind, rain, and snow.</rdfs:comment>
        <rdfs:label xml:lang="en">Outer Shell</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Pants -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Pants">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Layer"/>
        <rdfs:comment xml:lang="en">Lower body clothing for hiking, including both long and short variants.</rdfs:comment>
        <rdfs:label xml:lang="en">Pants</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Poles -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Poles">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Tools"/>
        <rdfs:comment xml:lang="en">Walking poles used for stability, balance, and reducing strain on knees during hiking.</rdfs:comment>
        <rdfs:label xml:lang="en">Trekking Poles</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Precipitation -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Precipitation">
        <rdfs:comment xml:lang="en">Any form of water falling from the atmosphere, including rain, snow, and hail.</rdfs:comment>
        <rdfs:label xml:lang="en">Precipitation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Rain -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Rain">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Precipitation"/>
        <rdfs:comment xml:lang="en">Precipitation in the form of liquid water droplets.</rdfs:comment>
        <rdfs:label xml:lang="en">Rain</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Rampons -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Rampons">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Tools"/>
        <rdfs:comment xml:lang="en">Traction devices with metal spikes attached to footwear for walking on ice and snow.</rdfs:comment>
        <rdfs:label xml:lang="en">Crampons</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Rope -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Rope">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Tools"/>
        <rdfs:comment xml:lang="en">Climbing or safety rope used for technical sections, river crossings, or emergency situations.</rdfs:comment>
        <rdfs:label xml:lang="en">Rope</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Season -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Season">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/Autumn"/>
                    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/Spring"/>
                    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/Summer"/>
                    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/Winter"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">The four seasons of the year: Spring, Summer, Autumn, and Winter.</rdfs:comment>
        <rdfs:label xml:lang="en">Season</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Shirt -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Shirt">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Base"/>
        <owl:disjointWith rdf:resource="http://www.unito.it/ontologies/trekconsult/ThermalSuit"/>
        <rdfs:comment xml:lang="en">Upper body base layer garment for moisture management and comfort.</rdfs:comment>
        <rdfs:label xml:lang="en">Shirt</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Shoes -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Shoes">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Equipment"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/HighShoes"/>
            <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/LowShoes"/>
            <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/MidShoes"/>
        </owl:disjointUnionOf>
        <rdfs:comment xml:lang="en">Footwear for hiking, including low, mid, and high-cut options for different terrain types.</rdfs:comment>
        <rdfs:label xml:lang="en">Shoes</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/ShortPants -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/ShortPants">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Pants"/>
        <rdfs:comment xml:lang="en">Shorts or short pants suitable for warm weather hiking.</rdfs:comment>
        <rdfs:label xml:lang="en">Short Pants</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/SmallBackpack -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/SmallBackpack">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.unito.it/ontologies/trekconsult/Backpack"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.unito.it/ontologies/trekconsult/hasCapacity"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#positiveInteger">20</xsd:maxInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Backpack"/>
        <rdfs:comment xml:lang="en">A small-capacity backpack (typically under 30 liters) for short day hikes.</rdfs:comment>
        <rdfs:label xml:lang="en">Small Backpack</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Snow -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Snow">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Precipitation"/>
        <rdfs:comment xml:lang="en">Precipitation in the form of ice crystals.</rdfs:comment>
        <rdfs:label xml:lang="en">Snow</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Snowshoes -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Snowshoes">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Tools"/>
        <rdfs:comment xml:lang="en">Footwear designed to distribute weight over a larger area for walking on snow.</rdfs:comment>
        <rdfs:label xml:lang="en">Snowshoes</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Snowy -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Snowy">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Terrain"/>
        <rdfs:comment xml:lang="en">Terrain covered with snow, requiring specialized equipment like snowshoes or crampons.</rdfs:comment>
        <rdfs:label xml:lang="en">Snowy Terrain</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/SunHat -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/SunHat">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Hat"/>
        <owl:disjointWith rdf:resource="http://www.unito.it/ontologies/trekconsult/WoolHat"/>
        <rdfs:comment xml:lang="en">A wide-brimmed hat for protection from sun exposure.</rdfs:comment>
        <rdfs:label xml:lang="en">Sun Hat</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Tent -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Tent">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/ontologies/trekconsult/Tools"/>
        <rdfs:comment xml:lang="en">Portable shelter for camping during multi-day hikes.</rdfs:comment>
        <rdfs:label xml:lang="en">Tent</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/ontologies/trekconsult/Terrain -->

    <owl:Class rdf:about="http://www.unito.it/ontologies/trekconsult/Terrain">
