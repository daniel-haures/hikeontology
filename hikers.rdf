                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult/date"/>
