                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#chalanges"/>
                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult/h"/>
