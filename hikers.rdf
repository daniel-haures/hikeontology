                                                                                                <swrl:classPredicate rdf:resource="http://www.unito.it/ontologies/trekconsult/OuterShell"/>
                                                                                                <swrl:argument1 rdf:resource="http://www.unito.it/ontologies/trekconsult/o"/>
                                                                                            </rdf:Description>
                                                                                        </rdf:first>
