        <Literal xml:lang="en">Protective eyewear for sun protection and visibility enhancement during hiking.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Glasses</IRI>
