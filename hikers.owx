        <Literal xml:lang="en">Protective headgear for safety during climbing, via ferrata, or technical trails.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Helmet</IRI>
        <Literal xml:lang="en">Helmet</Literal>
