    <DLSafeRule>
        <Annotation>
            <AnnotationProperty IRI="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
            <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
            <Literal>If the hike is a ferrata, then the ferrata kit is required.</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:label"/>
            <Literal>ViaFerrata_Req</Literal>
        </Annotation>
        <Body>
            <ClassAtom>
                <Class IRI="#Ferrata"/>
                <Variable IRI="/t"/>
            </ClassAtom>
            <ClassAtom>
                <Class IRI="#Hike"/>
                <Variable IRI="/h"/>
            </ClassAtom>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#chalanges"/>
                <Variable IRI="/h"/>
                <Variable IRI="/t"/>
            </ObjectPropertyAtom>
            <DataPropertyAtom>
                <DataProperty IRI="#basicEquipement"/>
                <Variable IRI="/o"/>
                <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
            </DataPropertyAtom>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#hasMember"/>
                <NamedIndividual IRI="#ViaFerrataEquipmentSet"/>
                <Variable IRI="/o"/>
            </ObjectPropertyAtom>
        </Body>
        <Head>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#requiresEquipement"/>
                <Variable IRI="/h"/>
                <Variable IRI="/o"/>
            </ObjectPropertyAtom>
        </Head>
    </DLSafeRule>
    <DLSafeRule>
        <Annotation>
            <AnnotationProperty IRI="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
            <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
            <Literal>This rule requires the sun hat if the hike weather is warm</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:label"/>
            <Literal>SunHat_Req</Literal>
        </Annotation>
        <Body>
            <ClassAtom>
                <Class IRI="#Trail"/>
                <Variable IRI="/t"/>
            </ClassAtom>
            <ClassAtom>
                <Class IRI="#Hike"/>
                <Variable IRI="/h"/>
            </ClassAtom>
            <DataPropertyAtom>
                <DataProperty IRI="#hikeDate"/>
                <Variable IRI="/h"/>
                <Variable IRI="/d2"/>
            </DataPropertyAtom>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#chalanges"/>
                <Variable IRI="/h"/>
                <Variable IRI="/t"/>
            </ObjectPropertyAtom>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#hasWeather"/>
                <Variable IRI="/t"/>
                <Variable IRI="/w"/>
            </ObjectPropertyAtom>
            <ClassAtom>
                <Class IRI="#Hot"/>
                <Variable IRI="/w"/>
            </ClassAtom>
            <DataPropertyAtom>
                <DataProperty IRI="#weatherInDate"/>
                <Variable IRI="/w"/>
                <Variable IRI="/d1"/>
            </DataPropertyAtom>
            <ClassAtom>
                <Class IRI="#SunHat"/>
                <Variable IRI="/o"/>
            </ClassAtom>
            <DataPropertyAtom>
                <DataProperty IRI="#basicEquipement"/>
                <Variable IRI="/o"/>
                <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
            </DataPropertyAtom>
        </Body>
        <Head>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#requiresEquipement"/>
                <Variable IRI="/h"/>
                <Variable IRI="/o"/>
            </ObjectPropertyAtom>
        </Head>
    </DLSafeRule>
    <DLSafeRule>
        <Annotation>
            <AnnotationProperty IRI="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
            <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
            <Literal>The rule implies that an outer shell is raining if rain is forecast for a hike</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:label"/>
            <Literal>OuterShell_Req</Literal>
        </Annotation>
        <Body>
            <ClassAtom>
                <Class IRI="#Trail"/>
                <Variable IRI="/t"/>
            </ClassAtom>
            <ClassAtom>
                <Class IRI="#Hike"/>
                <Variable IRI="/h"/>
            </ClassAtom>
            <DataPropertyAtom>
                <DataProperty IRI="#hikeDate"/>
                <Variable IRI="/h"/>
                <Variable IRI="/d2"/>
            </DataPropertyAtom>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#chalanges"/>
                <Variable IRI="/h"/>
                <Variable IRI="/t"/>
            </ObjectPropertyAtom>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#hasPrecipitation"/>
                <Variable IRI="/t"/>
                <Variable IRI="/p"/>
            </ObjectPropertyAtom>
            <DataPropertyAtom>
                <DataProperty IRI="#precipitationInDate"/>
                <Variable IRI="/p"/>
                <Variable IRI="/d1"/>
            </DataPropertyAtom>
            <ClassAtom>
                <Class IRI="#Rain"/>
                <Variable IRI="/p"/>
            </ClassAtom>
            <ClassAtom>
                <Class IRI="#OuterShell"/>
                <Variable IRI="/o"/>
            </ClassAtom>
            <DataPropertyAtom>
                <DataProperty IRI="#basicEquipement"/>
                <Variable IRI="/o"/>
                <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
            </DataPropertyAtom>
            <BuiltInAtom IRI="http://www.w3.org/2003/11/swrlb#equal">
                <Variable IRI="/d1"/>
                <Variable IRI="/d2"/>
            </BuiltInAtom>
        </Body>
        <Head>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#requiresEquipement"/>
                <Variable IRI="/h"/>
                <Variable IRI="/o"/>
            </ObjectPropertyAtom>
        </Head>
    </DLSafeRule>
    <DLSafeRule>
        <Annotation>
            <AnnotationProperty IRI="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
            <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
            <Literal>If the type of the hike is trekking, then poles are required</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:label"/>
            <Literal>TrekingPoles_Req</Literal>
        </Annotation>
        <Body>
            <ClassAtom>
                <Class IRI="#Treking"/>
                <Variable IRI="/t"/>
            </ClassAtom>
            <ClassAtom>
                <Class IRI="#Hike"/>
                <Variable IRI="/h"/>
            </ClassAtom>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#chalanges"/>
                <Variable IRI="/h"/>
                <Variable IRI="/t"/>
            </ObjectPropertyAtom>
            <ClassAtom>
                <Class IRI="#Poles"/>
                <Variable IRI="/o"/>
            </ClassAtom>
            <DataPropertyAtom>
                <DataProperty IRI="#basicEquipement"/>
                <Variable IRI="/o"/>
                <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
            </DataPropertyAtom>
        </Body>
        <Head>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#requiresEquipement"/>
                <Variable IRI="/h"/>
                <Variable IRI="/o"/>
            </ObjectPropertyAtom>
        </Head>
    </DLSafeRule>
    <DLSafeRule>
        <Annotation>
            <AnnotationProperty IRI="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
            <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
            <Literal>This rule implies that the season is spring based on the hike date</Literal>
        </Annotation>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:label"/>
            <Literal>SpringSeason</Literal>
        </Annotation>
        <Body>
            <ClassAtom>
                <Class IRI="#Hike"/>
                <Variable IRI="/x"/>
            </ClassAtom>
            <DataPropertyAtom>
                <DataProperty IRI="#hikeDate"/>
                <Variable IRI="/x"/>
                <Variable IRI="/date"/>
            </DataPropertyAtom>
            <BuiltInAtom IRI="http://www.w3.org/2003/11/swrlb#greaterThanOrEqual">
                <Variable IRI="/date"/>
                <Literal>2026-03-20</Literal>
            </BuiltInAtom>
            <BuiltInAtom IRI="http://www.w3.org/2003/11/swrlb#lessThanOrEqual">
                <Variable IRI="/date"/>
                <Literal>2026-06-21</Literal>
            </BuiltInAtom>
        </Body>
        <Head>
            <ObjectPropertyAtom>
                <ObjectProperty IRI="#hasSeason"/>
                <Variable IRI="/x"/>
                <NamedIndividual IRI="#Spring"/>
            </ObjectPropertyAtom>
        </Head>
    </DLSafeRule>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Autumn</IRI>
        <Literal xml:lang="en">The autumn season, typically characterized by cooling temperatures and changing foliage.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Autumn</IRI>
        <Literal xml:lang="en">Autumn</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Axe</IRI>
        <Literal xml:lang="en">A cutting tool used for chopping wood or clearing vegetation on trails.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Axe</IRI>
        <Literal xml:lang="en">Axe</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Backpack</IRI>
        <Literal xml:lang="en">A bag carried on one&apos;s back for holding equipment and supplies during hiking.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Backpack</IRI>
        <Literal xml:lang="en">Backpack</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Base</IRI>
        <Literal xml:lang="en">The innermost layer of clothing worn next to the skin, designed for moisture wicking and temperature regulation.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Base</IRI>
        <Literal xml:lang="en">Base Layer</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Closed</IRI>
        <Literal xml:lang="en">Terrain characterized by dense vegetation, forests, or narrow paths with limited visibility.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Closed</IRI>
        <Literal xml:lang="en">Closed Terrain</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Cold</IRI>
        <Literal xml:lang="en">Weather conditions with temperatures below 10 degrees Celsius.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Cold</IRI>
        <Literal xml:lang="en">Cold Weather</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Equipment</IRI>
        <Literal xml:lang="en">General category for all hiking and trekking equipment including clothing, tools, and accessories.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Equipment</IRI>
        <Literal xml:lang="en">Equipement</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#EquipmentSet</IRI>
        <Literal xml:lang="en">An equipment set</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#EquipmentSet</IRI>
        <Literal xml:lang="en">Equipment Set</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Ferrata</IRI>
        <Literal xml:lang="en">A protected climbing route with fixed cables, ladders, and bridges allowing access to difficult terrain.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Ferrata</IRI>
        <Literal xml:lang="en">Via Ferrata</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Fleece</IRI>
        <Literal xml:lang="en">A synthetic mid-layer garment made from fleece material for warmth and insulation.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Fleece</IRI>
        <Literal xml:lang="en">Fleece</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
