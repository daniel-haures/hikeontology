trekconsult:Winter rdf:type owl:NamedIndividual ,
                            trekconsult:Season ;
                   rdfs:comment "The winter season, typically characterized by cold temperatures and snow."@en ;
                   rdfs:label "Winter"@en .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( trekconsult:Backpack
                trekconsult:Hat
                trekconsult:Layer
                trekconsult:Shoes
                trekconsult:Tools
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( trekconsult:Base
                trekconsult:Insulation
                trekconsult:Mid
                trekconsult:OuterShell
                trekconsult:Pants
              )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( trekconsult:Autumn
                        trekconsult:Spring
                        trekconsult:Summer
                        trekconsult:Winter
                      )
] .


