@prefix : <http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix geos: <http://www.opengis.net/ont/geosparql#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sweet: <http://sweetontology.net/matrPrecipitation/> .
@prefix sweetpa: <http://sweetontology.net/phenAtmo/> .
@prefix trekconsult: <http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#> .
@base <http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult/> .

<http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#chalanges
trekconsult:chalanges rdf:type owl:ObjectProperty ,
                               owl:FunctionalProperty ,
                               owl:AsymmetricProperty ,
                               owl:IrreflexiveProperty ;
                      rdfs:domain trekconsult:Hike ;
                      rdfs:range trekconsult:Trail ;
                      rdfs:comment "A organized hike involves chalanging a certain mountain trail" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasEquipement
trekconsult:hasEquipement rdf:type owl:ObjectProperty ;
                          rdfs:domain trekconsult:Hike ;
                          rdfs:range trekconsult:Equipment ;
                          owl:propertyChainAxiom ( trekconsult:hasEquipementSet
                                                   trekconsult:hasMember
                                                 ) ;
                          rdfs:comment "A certain equipment can be used on a organized Hike." .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasEquipementSet
trekconsult:hasEquipementSet rdf:type owl:ObjectProperty ,
                                      owl:FunctionalProperty ,
                                      owl:AsymmetricProperty ,
                                      owl:IrreflexiveProperty ;
                             rdfs:domain trekconsult:Hike ;
                             rdfs:range trekconsult:EquipmentSet ;
                             rdfs:comment "Own a set of equipments" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasMember
trekconsult:hasMember rdf:type owl:ObjectProperty ;
                      owl:inverseOf trekconsult:isMemberOf ;
                      rdfs:domain trekconsult:EquipmentSet ;
                      rdfs:range trekconsult:Equipment ;
                      rdfs:comment "A colection has a certain member" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasPrecipitation
trekconsult:hasPrecipitation rdf:type owl:ObjectProperty ,
                                      owl:InverseFunctionalProperty ,
                                      owl:AsymmetricProperty ,
                                      owl:IrreflexiveProperty ;
                             rdfs:domain trekconsult:Trail ;
                             rdfs:range trekconsult:Precipitation ;
                             rdfs:comment "A trail retrieves the presence of a certain athmoferical precipitation" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasSeason
trekconsult:hasSeason rdf:type owl:ObjectProperty ,
                               owl:FunctionalProperty ,
                               owl:AsymmetricProperty ,
                               owl:IrreflexiveProperty ;
                      rdfs:domain trekconsult:Hike ;
                      rdfs:range trekconsult:Season ;
                      rdfs:comment "The season when a certain event takes place" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasTerrain
trekconsult:hasTerrain rdf:type owl:ObjectProperty ,
                                owl:InverseFunctionalProperty ,
                                owl:AsymmetricProperty ,
                                owl:IrreflexiveProperty ;
                       rdfs:domain trekconsult:Trail ;
                       rdfs:range trekconsult:Terrain ;
                       rdfs:comment "A certain trail return a certain terrain status" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasWeather
trekconsult:hasWeather rdf:type owl:ObjectProperty ,
                                owl:InverseFunctionalProperty ,
                                owl:AsymmetricProperty ,
                                owl:IrreflexiveProperty ;
                       rdfs:domain trekconsult:Trail ;
                       rdfs:range trekconsult:Weather ;
                       rdfs:comment "A trail retrieves a certain weather status for certain date" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#isMemberOf
trekconsult:isMemberOf rdf:type owl:ObjectProperty ;
                       rdfs:comment "Is a member of a certain collection" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#requiresEquipement
trekconsult:requiresEquipement rdf:type owl:ObjectProperty ,
                                        owl:AsymmetricProperty ,
                                        owl:IrreflexiveProperty ;
                               rdfs:domain trekconsult:Hike ;
                               rdfs:range trekconsult:Equipment ;
                               rdfs:comment "A certain trail can require a certain equipment" .


###  http://www.w3.org/2002/07/owl#topObjectProperty
owl:topObjectProperty owl:inverseOf owl:topObjectProperty .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#basicEquipement
trekconsult:basicEquipement rdf:type owl:DatatypeProperty ,
                                     owl:FunctionalProperty ;
                            rdfs:domain trekconsult:Equipment ;
                            rdfs:range xsd:boolean ;
                            rdfs:comment "The equipment is the entry level option" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#circularTrail
trekconsult:circularTrail rdf:type owl:DatatypeProperty ,
                                   owl:FunctionalProperty ;
                          rdfs:domain trekconsult:Trail ;
                          rdfs:range xsd:boolean ;
                          rdfs:comment "The trail is closed" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#distanceTrail
trekconsult:distanceTrail rdf:type owl:DatatypeProperty ,
                                   owl:FunctionalProperty ;
                          rdfs:domain trekconsult:Trail ;
                          rdfs:range xsd:float ;
                          rdfs:comment "The lenght in KM of a trail" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasCapacity
trekconsult:hasCapacity rdf:type owl:DatatypeProperty ,
                                 owl:FunctionalProperty ;
                        rdfs:domain trekconsult:Equipment ;
                        rdfs:range xsd:positiveInteger ;
                        rdfs:comment "The capacity of a backpack" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasElevationGain
trekconsult:hasElevationGain rdf:type owl:DatatypeProperty ,
                                      owl:FunctionalProperty ;
                             rdfs:domain trekconsult:Trail ;
                             rdfs:range xsd:positiveInteger ;
                             rdfs:comment "A trail has an elevation gain" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hasTemperatureValue
trekconsult:hasTemperatureValue rdf:type owl:DatatypeProperty ,
                                         owl:FunctionalProperty ;
                                rdfs:domain trekconsult:Weather ;
                                rdfs:range xsd:float ;
                                rdfs:comment "The weather temperature in Celsius" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#hikeDate
trekconsult:hikeDate rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain trekconsult:Hike ;
                     rdfs:range xsd:string ;
                     rdfs:comment "The date when the hike is organized" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#isWaterProof
trekconsult:isWaterProof rdf:type owl:DatatypeProperty ,
                                  owl:FunctionalProperty ;
                         rdfs:domain trekconsult:Equipment ;
                         rdfs:range xsd:boolean ;
                         rdfs:comment "Describes if the equipment is waterproof" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#precipitationInDate
trekconsult:precipitationInDate rdf:type owl:DatatypeProperty ,
                                         owl:FunctionalProperty ;
                                rdfs:domain trekconsult:Precipitation ;
                                rdfs:range xsd:string ;
                                rdfs:comment "Describe the date when a particular atmospherical precipitation has taken place" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#reacheableByTrain
trekconsult:reacheableByTrain rdf:type owl:DatatypeProperty ,
                                       owl:FunctionalProperty ;
                              rdfs:domain trekconsult:Trail ;
                              rdfs:range xsd:boolean ;
                              rdfs:comment "Is true when a certain trail is reacheable by trail" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#requiresCar
trekconsult:requiresCar rdf:type owl:DatatypeProperty ;
                        rdfs:domain trekconsult:Trail ;
                        rdfs:range xsd:boolean ;
                        rdfs:comment "A trail is reacheable only by car" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#requiresWater
trekconsult:requiresWater rdf:type owl:DatatypeProperty ,
                                   owl:FunctionalProperty ;
                          rdfs:domain trekconsult:Trail ;
                          rdfs:range xsd:boolean ;
                          rdfs:comment "If the trail doesn't have some point where to collect water, the a water tank from home is required" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#terrainInDate
trekconsult:terrainInDate rdf:type owl:DatatypeProperty ,
                                   owl:FunctionalProperty ;
                          rdfs:domain trekconsult:Terrain ;
                          rdfs:range xsd:string ;
                          rdfs:comment "Describes the date where a certain terain status of trail is checked." .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#trailLevel
trekconsult:trailLevel rdf:type owl:DatatypeProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain trekconsult:Trail ;
                       rdfs:range xsd:string ;
                       rdfs:comment "Decribes the dificulty of the trail" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#weatherInDate
trekconsult:weatherInDate rdf:type owl:DatatypeProperty ,
                                   owl:FunctionalProperty ;
                          rdfs:domain trekconsult:Weather ;
                          rdfs:range xsd:string ;
                          rdfs:comment "Describes the date were the weather conditions were forecast." .


#################################################################
#    Classes
#################################################################

###  http://dbpedia.org/ontology/Device
<http://dbpedia.org/ontology/Device> rdf:type owl:Class .


###  http://sweetontology.net/phenAtmoPrecipitation/AtmosphericPrecipitation
<http://sweetontology.net/phenAtmoPrecipitation/AtmosphericPrecipitation> rdf:type owl:Class ;
                                                                          owl:equivalentClass trekconsult:Precipitation .


###  http://www.opengis.net/ont/geosparql#Feature
geos:Feature rdf:type owl:Class .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Axe
trekconsult:Axe rdf:type owl:Class ;
                rdfs:subClassOf trekconsult:Tools ;
                rdfs:comment "A cutting tool used for chopping wood or clearing vegetation on trails."@en ;
                rdfs:label "Axe"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Backpack
trekconsult:Backpack rdf:type owl:Class ;
                     rdfs:subClassOf trekconsult:Equipment ;
                     owl:disjointUnionOf ( trekconsult:LargeBackpack
                                           trekconsult:MidBackpack
                                           trekconsult:SmallBackpack
                                         ) ;
                     rdfs:comment "A bag carried on one's back for holding equipment and supplies during hiking."@en ;
                     rdfs:label "Backpack"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Base
trekconsult:Base rdf:type owl:Class ;
                 rdfs:subClassOf trekconsult:Layer ;
                 rdfs:comment "The innermost layer of clothing worn next to the skin, designed for moisture wicking and temperature regulation."@en ;
                 rdfs:label "Base Layer"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Closed
trekconsult:Closed rdf:type owl:Class ;
                   rdfs:subClassOf trekconsult:Terrain ;
                   rdfs:comment "Terrain characterized by dense vegetation, forests, or narrow paths with limited visibility."@en ;
                   rdfs:label "Closed Terrain"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Cold
trekconsult:Cold rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( trekconsult:Weather
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty trekconsult:hasTemperatureValue ;
                                                              owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                   owl:onDatatype xsd:float ;
                                                                                   owl:withRestrictions ( [ xsd:maxExclusive "10.0"^^xsd:float
                                                                                                          ]
                                                                                                        )
                                                                                 ]
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:subClassOf trekconsult:Weather ;
                 rdfs:comment "Weather conditions with temperatures below 10 degrees Celsius."@en ;
                 rdfs:label "Cold Weather"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Equipment
trekconsult:Equipment rdf:type owl:Class ;
                      rdfs:subClassOf <http://dbpedia.org/ontology/Device> ;
                      rdfs:comment "General category for all hiking and trekking equipment including clothing, tools, and accessories."@en ;
                      rdfs:label "Equipement"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#EquipmentSet
trekconsult:EquipmentSet rdf:type owl:Class ;
                         rdfs:comment "An equipment set"@en ;
                         rdfs:label "Equipment Set"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Ferrata
trekconsult:Ferrata rdf:type owl:Class ;
                    rdfs:subClassOf trekconsult:Trail ;
                    rdfs:comment "A protected climbing route with fixed cables, ladders, and bridges allowing access to difficult terrain."@en ;
                    rdfs:label "Via Ferrata"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Fleece
trekconsult:Fleece rdf:type owl:Class ;
                   rdfs:subClassOf trekconsult:Mid ;
                   owl:disjointWith trekconsult:WoolHoodie ;
                   rdfs:comment "A synthetic mid-layer garment made from fleece material for warmth and insulation."@en ;
                   rdfs:label "Fleece"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Glasses
trekconsult:Glasses rdf:type owl:Class ;
                    rdfs:subClassOf trekconsult:Tools ;
                    rdfs:comment "Protective eyewear for sun protection and visibility enhancement during hiking."@en ;
                    rdfs:label "Glasses"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Harness
trekconsult:Harness rdf:type owl:Class ;
                    rdfs:subClassOf trekconsult:Tools ;
                    rdfs:comment "A safety harness used for climbing and via ferrata routes."@en ;
                    rdfs:label "Harness"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hat
trekconsult:Hat rdf:type owl:Class ;
                rdfs:subClassOf trekconsult:Equipment ;
                rdfs:comment "Headwear for protection from sun, cold, or other weather conditions."@en ;
                rdfs:label "Hat"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Helmet
trekconsult:Helmet rdf:type owl:Class ;
                   rdfs:subClassOf trekconsult:Tools ;
                   rdfs:comment "Protective headgear for safety during climbing, via ferrata, or technical trails."@en ;
                   rdfs:label "Helmet"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#HighShoes
trekconsult:HighShoes rdf:type owl:Class ;
                      rdfs:subClassOf trekconsult:Shoes ;
                      rdfs:comment "High-cut hiking boots providing maximum ankle support and stability for difficult terrain."@en ;
                      rdfs:label "High Shoes"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hike
trekconsult:Hike rdf:type owl:Class ;
                 rdfs:comment "An organized hike that chalanges a particular trail" .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Hot
trekconsult:Hot rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( trekconsult:Weather
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty trekconsult:hasTemperatureValue ;
                                                             owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                  owl:onDatatype xsd:float ;
                                                                                  owl:withRestrictions ( [ xsd:minInclusive "25.0"^^xsd:float
                                                                                                         ]
                                                                                                       )
                                                                                ]
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf trekconsult:Weather ;
                rdfs:comment "Weather conditions with temperatures at or above 25 degrees Celsius."@en ;
                rdfs:label "Hot Weather"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Iced
trekconsult:Iced rdf:type owl:Class ;
                 rdfs:subClassOf trekconsult:Terrain ;
                 rdfs:comment "Terrain covered with ice, requiring specialized equipment like crampons."@en ;
                 rdfs:label "Iced Terrain"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Insulation
trekconsult:Insulation rdf:type owl:Class ;
                       rdfs:subClassOf trekconsult:Layer ;
                       rdfs:comment "Middle clothing layer designed to provide warmth by trapping body heat."@en ;
                       rdfs:label "Insulation Layer"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#LargeBackpack
trekconsult:LargeBackpack rdf:type owl:Class ;
                          owl:equivalentClass [ owl:intersectionOf ( trekconsult:Backpack
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty trekconsult:hasCapacity ;
                                                                       owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                            owl:onDatatype xsd:positiveInteger ;
                                                                                            owl:withRestrictions ( [ xsd:minInclusive "60"^^xsd:positiveInteger
                                                                                                                   ]
                                                                                                                 )
                                                                                          ]
                                                                     ]
                                                                   ) ;
                                                rdf:type owl:Class
                                              ] ;
                          rdfs:subClassOf trekconsult:Backpack ;
                          rdfs:comment "A large-capacity backpack (typically 50+ liters) for multi-day treks and extended expeditions."@en ;
                          rdfs:label "Large Backpack"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Layer
trekconsult:Layer rdf:type owl:Class ;
                  rdfs:subClassOf trekconsult:Equipment ;
                  rdfs:comment "Clothing layers used in the layering system for outdoor activities (base, mid, insulation, outer shell, pants)."@en ;
                  rdfs:label "Layer"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#LongPants
trekconsult:LongPants rdf:type owl:Class ;
                      rdfs:subClassOf trekconsult:Pants ;
                      rdfs:comment "Full-length pants providing protection from cold, insects, and vegetation."@en ;
                      rdfs:label "Long Pants"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#LowShoes
trekconsult:LowShoes rdf:type owl:Class ;
                     rdfs:subClassOf trekconsult:Shoes ;
                     rdfs:comment "Low-cut hiking shoes or trail runners, suitable for easy trails and day hikes."@en ;
                     rdfs:label "Low Shoes"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Mid
trekconsult:Mid rdf:type owl:Class ;
                rdfs:subClassOf trekconsult:Layer ;
                rdfs:comment "Middle clothing layer providing additional insulation and moisture management."@en ;
                rdfs:label "Mid Layer"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#MidBackpack
trekconsult:MidBackpack rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( trekconsult:Backpack
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty trekconsult:hasCapacity ;
                                                                     owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                          owl:onDatatype xsd:positiveInteger ;
                                                                                          owl:withRestrictions ( [ xsd:minExclusive "20"^^xsd:positiveInteger
                                                                                                                 ]
                                                                                                                 [ xsd:maxExclusive "60"^^xsd:positiveInteger
                                                                                                                 ]
                                                                                                               )
                                                                                        ]
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf trekconsult:Backpack ;
                        rdfs:comment "A medium-capacity backpack (typically 30-50 liters) for day hikes and short overnight trips."@en ;
                        rdfs:label "Medium Backpack"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#MidShoes
trekconsult:MidShoes rdf:type owl:Class ;
                     rdfs:subClassOf trekconsult:Shoes ;
                     rdfs:comment "Mid-cut hiking boots providing ankle support and stability on moderate terrain."@en ;
                     rdfs:label "Mid Shoes"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Mild
trekconsult:Mild rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( trekconsult:Weather
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty trekconsult:hasTemperatureValue ;
                                                              owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                   owl:onDatatype xsd:float ;
                                                                                   owl:withRestrictions ( [ xsd:minInclusive "10.0"^^xsd:float
                                                                                                          ]
                                                                                                          [ xsd:maxExclusive "25.0"^^xsd:float
                                                                                                          ]
                                                                                                        )
                                                                                 ]
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:subClassOf trekconsult:Weather ;
                 rdfs:comment "Weather conditions with moderate temperatures between 10 and 25 degrees Celsius."@en ;
                 rdfs:label "Mild Weather"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Mountaneering
trekconsult:Mountaneering rdf:type owl:Class ;
                          rdfs:subClassOf trekconsult:Trail ;
                          rdfs:comment "A technical mountain trail requiring specialized climbing skills and equipment."@en ;
                          rdfs:label "Mountaineering"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#OuterShell
trekconsult:OuterShell rdf:type owl:Class ;
                       rdfs:subClassOf trekconsult:Layer ;
                       rdfs:comment "Outermost clothing layer providing protection from wind, rain, and snow."@en ;
                       rdfs:label "Outer Shell"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Pants
trekconsult:Pants rdf:type owl:Class ;
                  rdfs:subClassOf trekconsult:Layer ;
                  rdfs:comment "Lower body clothing for hiking, including both long and short variants."@en ;
                  rdfs:label "Pants"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Poles
trekconsult:Poles rdf:type owl:Class ;
                  rdfs:subClassOf trekconsult:Tools ;
                  rdfs:comment "Walking poles used for stability, balance, and reducing strain on knees during hiking."@en ;
                  rdfs:label "Trekking Poles"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Precipitation
trekconsult:Precipitation rdf:type owl:Class ;
                          rdfs:comment "Any form of water falling from the atmosphere, including rain, snow, and hail."@en ;
                          rdfs:label "Precipitation"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Rain
trekconsult:Rain rdf:type owl:Class ;
                 rdfs:subClassOf trekconsult:Precipitation ;
                 rdfs:comment "Precipitation in the form of liquid water droplets."@en ;
                 rdfs:label "Rain"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Rampons
trekconsult:Rampons rdf:type owl:Class ;
                    rdfs:subClassOf trekconsult:Tools ;
                    rdfs:comment "Traction devices with metal spikes attached to footwear for walking on ice and snow."@en ;
                    rdfs:label "Crampons"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Rope
trekconsult:Rope rdf:type owl:Class ;
                 rdfs:subClassOf trekconsult:Tools ;
                 rdfs:comment "Climbing or safety rope used for technical sections, river crossings, or emergency situations."@en ;
                 rdfs:label "Rope"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Season
trekconsult:Season rdf:type owl:Class ;
                   owl:equivalentClass [ rdf:type owl:Class ;
                                         owl:oneOf ( trekconsult:Autumn
                                                     trekconsult:Spring
                                                     trekconsult:Summer
                                                     trekconsult:Winter
                                                   )
                                       ] ;
                   rdfs:comment "The four seasons of the year: Spring, Summer, Autumn, and Winter."@en ;
                   rdfs:label "Season"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Shirt
trekconsult:Shirt rdf:type owl:Class ;
                  rdfs:subClassOf trekconsult:Base ;
                  owl:disjointWith trekconsult:ThermalSuit ;
                  rdfs:comment "Upper body base layer garment for moisture management and comfort."@en ;
                  rdfs:label "Shirt"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Shoes
trekconsult:Shoes rdf:type owl:Class ;
                  rdfs:subClassOf trekconsult:Equipment ;
                  owl:disjointUnionOf ( trekconsult:HighShoes
                                        trekconsult:LowShoes
                                        trekconsult:MidShoes
                                      ) ;
                  rdfs:comment "Footwear for hiking, including low, mid, and high-cut options for different terrain types."@en ;
                  rdfs:label "Shoes"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#ShortPants
trekconsult:ShortPants rdf:type owl:Class ;
                       rdfs:subClassOf trekconsult:Pants ;
                       rdfs:comment "Shorts or short pants suitable for warm weather hiking."@en ;
                       rdfs:label "Short Pants"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#SmallBackpack
trekconsult:SmallBackpack rdf:type owl:Class ;
                          owl:equivalentClass [ owl:intersectionOf ( trekconsult:Backpack
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty trekconsult:hasCapacity ;
                                                                       owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                            owl:onDatatype xsd:positiveInteger ;
                                                                                            owl:withRestrictions ( [ xsd:maxInclusive "20"^^xsd:positiveInteger
                                                                                                                   ]
                                                                                                                 )
                                                                                          ]
                                                                     ]
                                                                   ) ;
                                                rdf:type owl:Class
                                              ] ;
                          rdfs:subClassOf trekconsult:Backpack ;
                          rdfs:comment "A small-capacity backpack (typically under 30 liters) for short day hikes."@en ;
                          rdfs:label "Small Backpack"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Snow
trekconsult:Snow rdf:type owl:Class ;
                 rdfs:subClassOf trekconsult:Precipitation ;
                 rdfs:comment "Precipitation in the form of ice crystals."@en ;
                 rdfs:label "Snow"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Snowshoes
trekconsult:Snowshoes rdf:type owl:Class ;
                      rdfs:subClassOf trekconsult:Tools ;
                      rdfs:comment "Footwear designed to distribute weight over a larger area for walking on snow."@en ;
                      rdfs:label "Snowshoes"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Snowy
trekconsult:Snowy rdf:type owl:Class ;
                  rdfs:subClassOf trekconsult:Terrain ;
                  rdfs:comment "Terrain covered with snow, requiring specialized equipment like snowshoes or crampons."@en ;
                  rdfs:label "Snowy Terrain"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#SunHat
trekconsult:SunHat rdf:type owl:Class ;
                   rdfs:subClassOf trekconsult:Hat ;
                   owl:disjointWith trekconsult:WoolHat ;
                   rdfs:comment "A wide-brimmed hat for protection from sun exposure."@en ;
                   rdfs:label "Sun Hat"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tent
trekconsult:Tent rdf:type owl:Class ;
                 rdfs:subClassOf trekconsult:Tools ;
                 rdfs:comment "Portable shelter for camping during multi-day hikes."@en ;
                 rdfs:label "Tent"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Terrain
trekconsult:Terrain rdf:type owl:Class ;
                    rdfs:comment "The physical characteristics and surface type of a trail (open, closed, snowy, iced, etc.)."@en ;
                    rdfs:label "Terrain"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#ThermalSuit
trekconsult:ThermalSuit rdf:type owl:Class ;
                        rdfs:subClassOf trekconsult:Base ;
                        rdfs:comment "Full-body insulated base layer clothing for extreme cold conditions."@en ;
                        rdfs:label "Thermal Suit"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Tools
trekconsult:Tools rdf:type owl:Class ;
                  rdfs:subClassOf trekconsult:Equipment ;
                  owl:disjointUnionOf ( trekconsult:Axe
                                        trekconsult:Glasses
                                        trekconsult:Harness
                                        trekconsult:Helmet
                                        trekconsult:Poles
                                        trekconsult:Rampons
                                        trekconsult:Rope
                                        trekconsult:Snowshoes
                                        trekconsult:Tent
                                      ) ;
                  rdfs:comment "Specialized equipment and tools for hiking, including poles, ropes, crampons, and camping gear."@en ;
                  rdfs:label "Tools"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Trail
trekconsult:Trail rdf:type owl:Class ;
                  rdfs:subClassOf geos:Feature ;
                  rdfs:comment "A hiking or trekking route that can be characterized by terrain, weather conditions, and activity type."@en ;
                  rdfs:label "Trail"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Treking
trekconsult:Treking rdf:type owl:Class ;
                    rdfs:subClassOf trekconsult:Trail ;
                    rdfs:comment "A simple mountain trail"@en ;
                    rdfs:label "Trekking"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#Weather
trekconsult:Weather rdf:type owl:Class ;
                    rdfs:comment "Atmospheric conditions affecting a trail, including temperature, precipitation, and humidity."@en ;
                    rdfs:label "Weather"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#WoolHat
trekconsult:WoolHat rdf:type owl:Class ;
                    rdfs:subClassOf trekconsult:Hat ;
                    rdfs:comment "A warm hat made of wool for cold weather protection."@en ;
                    rdfs:label "Wool Hat"@en .


###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#WoolHoodie
trekconsult:WoolHoodie rdf:type owl:Class ;
                       rdfs:subClassOf trekconsult:Mid ;
                       rdfs:comment "A hooded mid-layer garment made of wool for warmth and comfort."@en ;
                       rdfs:label "Wool Hoodie"@en .


