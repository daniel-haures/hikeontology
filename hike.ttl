###  http://www.semanticweb.org/danielhaures/ontologies/2026/0/trekconsult#ViaFerrataEquipmentSet
trekconsult:ViaFerrataEquipmentSet rdf:type owl:NamedIndividual ,
                                            trekconsult:EquipmentSet ;
                                   trekconsult:hasMember trekconsult:Decathlon_Simond_Climbing_Harness ,
                                                         trekconsult:Decathlon_Simond_Climbing_Rope ,
                                                         trekconsult:Decathlon_Simond_Rock_Helmet ;
                                   rdfs:comment "Complete equipment set required for via ferrata climbing, including harness, helmet, and rope."@en ;
                                   rdfs:label "Via Ferrata Equipment Set"@en .


